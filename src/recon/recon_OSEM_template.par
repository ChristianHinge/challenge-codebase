OSMAPOSLParameters :=
; OSEM

objective function type:= PoissonLogLikelihoodWithLinearModelForMeanAndProjData
PoissonLogLikelihoodWithLinearModelForMeanAndProjData Parameters:=

input file := PROMPTS_SINO
zoom := 0.5

maximum absolute segment number to process := 4

; additive projection data
additive sinogram := ADD_SINO

projector pair type := Matrix
  Projector Pair Using Matrix Parameters :=
  Matrix type := Ray Tracing
  Ray tracing matrix parameters :=
number of rays in tangential direction to trace for each bin :=5
do symmetry 90degrees min phi := 0

  End Ray tracing matrix parameters :=
  End Projector Pair Using Matrix Parameters :=
use time-of-flight sensitivities := 1

; norm and acf
Bin Normalisation type := From ProjData
 Bin Normalisation From ProjData := 
 normalisation projdata filename:= MULT_SINO
End Bin Normalisation From ProjData:=

end PoissonLogLikelihoodWithLinearModelForMeanAndProjData Parameters:=

output filename prefix := OUT_FILE_PREFIX
number of subsets:= 5
number of subiterations:= 20
save estimates at subiteration intervals:= 20

post-filter type := Separable Gaussian
Separable Gaussian Filter Parameters :=
  x-dir filter FWHM (in mm):= 4.0
  y-dir filter FWHM (in mm):= 4.0
  z-dir filter FWHM (in mm):= 4.0
END Separable Gaussian Filter Parameters :=

END :=